{
    "name": "chatter/api",
    "description": "Chatter App REST API — CodeIgniter 4",
    "type": "project",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "^4.5"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "CodeIgniter\\ComposerScripts::postUpdate"
        ]
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
